NODE_ENV=development
PORT=8080
CORS_ORIGIN=http://localhost:5000,http://localhost:8081,http://127.0.0.1:8081
API_BASE_URL=http://localhost:4000
SUPER_ADMIN_KEY=change-me-long-random-secret
ENABLE_BOOTSTRAP_ADMIN=false
ADMIN_ACCESS_KEY=dev-only-change-me
ACCESS_CODE_PEPPER=replace-with-long-random-secret
CITIZEN_FINGERPRINT_PEPPER=replace-with-another-long-random-secret
ADMIN_ACCESS_PEPPER=replace-with-admin-access-pepper
CONTROLLER_CODE_PEPPER=replace-with-controller-code-pepper
VOTE_ACCESS_TOKEN_SECRET=change-me-long-random-token-secret
RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379

# Option 1: fichier service account local non commite
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-admin.json

# Option 2: variables explicites Firebase Admin
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"