rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAnonymousSession() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function hasRole(role) {
      return isSignedIn() && (
        request.auth.token.role == role ||
        request.auth.token[role] == true
      );
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isSuperAdmin() {
      return hasRole('super_admin');
    }

    function isAdminCommune() {
      return hasRole('adminCommune') || isAdmin();
    }

    function isController() {
      return hasRole('controller') || isAdmin();
    }

    function isControllerOwner(controllerId) {
      return isController() && (
        request.auth.uid == controllerId ||
        request.auth.token.controllerId == controllerId ||
        request.auth.token.controleurCodeId == controllerId ||
        request.auth.token.code == controllerId
      );
    }

    function isAccessCode(value) {
      return value is string && value.matches('^[A-F0-9]{8}$');
    }

    function isFingerprint(value) {
      return value is string && value.matches('^[a-f0-9]{64}$');
    }

    function isMaskedSource(value) {
      return value is string && value.matches('^[A-Z][A-Z][0-9]{6}$');
    }

    function isAccessStatus(value) {
      return value in ['active', 'replaced', 'revoked'];
    }

    function isDuplicateStatus(value) {
      return value in ['pending', 'approved', 'rejected'];
    }

    function isDuplicateReason(value) {
      return value in ['lost_code', 'unreadable_code', 'citizen_claims_no_access', 'controller_error', 'other'];
    }

    function isControllerAction(value) {
      return value in ['code_created', 'duplicate_detected', 'duplicate_request_created', 'regeneration_approved', 'regeneration_rejected', 'login_code_used'];
    }

    function hasOnlyKeys(allowedKeys) {
      return request.resource.data.keys().hasOnly(allowedKeys);
    }

    function isAdminProfileShape() {
      return hasOnlyKeys(['commune', 'updatedAt']);
    }

    function isPollShape() {
      return hasOnlyKeys(['id', 'projectTitle', 'question', 'options', 'openDate', 'closeDate', 'status', 'totalVoters', 'totalVoted', 'updatedAt']);
    }

    function isRegistrationCodeShape() {
      return hasOnlyKeys(['id', 'code', 'pollId', 'createdAt', 'usedBy', 'status', 'documentType', 'validatedAt', 'expiresAt', 'communeName', 'qrPayload', 'activatedAt', 'votedAt', 'verifiedByControleurCode', 'verifiedByControleurLabel', 'updatedAt']);
    }

    function isControleurCodeShape() {
      return hasOnlyKeys(['id', 'code', 'label', 'commune', 'createdAt', 'usedAt', 'updatedAt']);
    }

    function isControleurActivityShape() {
      return hasOnlyKeys(['id', 'controleurCode', 'controleurLabel', 'registrationCode', 'verifiedAt', 'createdAt']);
    }

    function isCitizenAccessCodeShape() {
      return hasOnlyKeys([
        'accessCode', 'fingerprint', 'sourceKeyMasked', 'firstNameInitial', 'lastNameInitial',
        'birthYear', 'phoneSuffix', 'communeId', 'communeName', 'createdByControllerId',
        'createdByControllerName', 'createdAt', 'status', 'usedForLogin', 'regeneratedFromCode',
        'regenerationIndex', 'approvedBySuperAdminId', 'approvedAt', 'updatedAt'
      ]) &&
      isAccessCode(request.resource.data.accessCode) &&
      isFingerprint(request.resource.data.fingerprint) &&
      isMaskedSource(request.resource.data.sourceKeyMasked) &&
      isAccessStatus(request.resource.data.status) &&
      request.resource.data.birthYear.matches('^[0-9]{4}$') &&
      request.resource.data.phoneSuffix.matches('^[0-9]{2}$') &&
      request.resource.data.regenerationIndex is int;
    }

    function isCitizenFingerprintShape() {
      return hasOnlyKeys([
        'fingerprint', 'sourceKeyMasked', 'firstAccessCode', 'latestAccessCode', 'communeId',
        'createdAt', 'updatedAt', 'regenerationCount'
      ]) &&
      isFingerprint(request.resource.data.fingerprint) &&
      isMaskedSource(request.resource.data.sourceKeyMasked) &&
      isAccessCode(request.resource.data.firstAccessCode) &&
      isAccessCode(request.resource.data.latestAccessCode) &&
      request.resource.data.regenerationCount is int;
    }

    function isDuplicateCodeRequestShape() {
      return hasOnlyKeys([
        'id', 'fingerprint', 'sourceKeyMasked', 'existingAccessCode', 'requestedByControllerId',
        'requestedByControllerName', 'communeId', 'communeName', 'requestedAt', 'status',
        'duplicateReason', 'controllerComment', 'reviewedBySuperAdminId', 'reviewedAt',
        'rejectionReason', 'newAccessCode', 'updatedAt'
      ]) &&
      isFingerprint(request.resource.data.fingerprint) &&
      isMaskedSource(request.resource.data.sourceKeyMasked) &&
      isAccessCode(request.resource.data.existingAccessCode) &&
      isDuplicateStatus(request.resource.data.status) &&
      isDuplicateReason(request.resource.data.duplicateReason) &&
      (!('newAccessCode' in request.resource.data) || request.resource.data.newAccessCode == null || isAccessCode(request.resource.data.newAccessCode));
    }

    function isControllerActivityLogShape() {
      return hasOnlyKeys([
        'id', 'communeId', 'communeName', 'controllerId', 'controllerName', 'actionType',
        'accessCode', 'fingerprint', 'sourceKeyMasked', 'createdAt', 'metadata', 'updatedAt'
      ]) &&
      isControllerAction(request.resource.data.actionType) &&
      (!('accessCode' in request.resource.data) || request.resource.data.accessCode == null || isAccessCode(request.resource.data.accessCode)) &&
      (!('fingerprint' in request.resource.data) || request.resource.data.fingerprint == null || isFingerprint(request.resource.data.fingerprint)) &&
      (!('sourceKeyMasked' in request.resource.data) || request.resource.data.sourceKeyMasked == null || isMaskedSource(request.resource.data.sourceKeyMasked));
    }

    function registrationCodeVoterUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['activatedAt', 'votedAt', 'updatedAt']);
    }

    function pollVoterUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['options', 'totalVoted', 'updatedAt']);
    }

    match /adminProfiles/{document=**} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // communeAdmins is fully backend-managed. Clients never read the
    // hashed access keys, never create or rotate admin profiles, only
    // the Admin SDK does.
    match /communeAdmins/{adminId} {
      allow read, write: if false;
    }

    // polls: public read, but writes are reserved to the Admin SDK so
    // the backend can scope updates to the right commune and audit
    // them. The previous "anonymous voter update" rule is gone because
    // votes now flow only through /api/vote-access/submit.
    match /polls/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // registrationCodes is the legacy citizen access pipeline. Migrate
    // documents into citizen_access_codes via the backend migration
    // script, then keep this rule denying everything client-side.
    match /registrationCodes/{document=**} {
      allow read, write: if false;
    }

    // controleurCodes: only the Admin SDK manages controller codes.
    // Reads need to be restricted because the document holds the raw
    // controller code that grants access to the controller dashboard.
    match /controleurCodes/{document=**} {
      allow read, write: if false;
    }

    match /controleurActivities/{document=**} {
      allow read: if isController();
      allow write: if isController() && isControleurActivityShape();
    }

    match /citizen_access_codes/{accessCode} {
      allow read: if isSuperAdmin();
      allow create, update: if false;
      allow delete: if false;
    }

    match /citizen_fingerprints/{fingerprint} {
      allow read: if isSuperAdmin();
      allow create, update: if false;
      allow delete: if false;
    }

    match /duplicate_code_requests/{requestId} {
      allow read: if isSuperAdmin();
      allow create: if false;
      allow update: if isSuperAdmin() && isDuplicateCodeRequestShape();
      allow delete: if false;
    }

    match /controller_activity_logs/{logId} {
      allow read: if isSuperAdmin() || isAdminCommune();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Vote anonyme: cle de doc {pollId}_{accessCodeId}.
    // Aucun acces client. Lecture/ecriture exclusivement via le backend
    // (Firebase Admin SDK contourne ces regles) afin de garantir la
    // transactionnalite et l'anonymat des votes.
    match /poll_votes/{voteId} {
      allow read, write: if false;
    }

    // Cache public d'horodatage des votes pour le tableau de bord citoyen.
    // Le backend reste la source de verite (poll_votes). Le client n'ecrit pas.
    match /citizen_poll_access/{document=**} {
      allow read: if isAdminCommune() || isSuperAdmin();
      allow write: if false;
    }

    // Actualites publiques publiees par les administrateurs communaux.
    // Lecture libre, ecriture exclusivement via /api/news (Admin SDK).
    match /public_news/{newsId} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}