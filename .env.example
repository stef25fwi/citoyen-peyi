NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173,http://localhost:8081,http://127.0.0.1:8081
API_BASE_URL=http://localhost:4000
LOG_LEVEL=info

# Long random strings (>=48 chars). Rotate before each production deploy.
SUPER_ADMIN_KEY=replace-with-long-random-secret
ADMIN_ACCESS_KEY=replace-with-long-random-secret
VOTE_ACCESS_TOKEN_SECRET=replace-with-long-random-token-secret
ACCESS_CODE_PEPPER=replace-with-access-code-pepper
CITIZEN_FINGERPRINT_PEPPER=replace-with-citizen-fingerprint-pepper
PARTICIPATION_PEPPER=replace-with-participation-pepper
ADMIN_ACCESS_PEPPER=replace-with-admin-access-pepper
CONTROLLER_CODE_PEPPER=replace-with-controller-code-pepper
RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379

# Option 1: path to a service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-admin.json

# Option 2: inline service account credentials
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
